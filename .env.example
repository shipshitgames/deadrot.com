# Asset-generation provider keys. Copy to `.env` (gitignored) and fill in.
#
#   cp .env.example .env
#
# These power the studio asset pipeline (codex/assetgen images + ElevenLabs SFX).

# ElevenLabs — Sound Effects / TTS API (weapon SFX, voice lines).
# Get a key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# OpenAI — gpt-image-2 image generation (optional fallback; the codex CLI's
# built-in image_gen is the default image path and needs no key).
OPENAI_API_KEY=
