# Asset-generation provider keys. Copy to `.env` (gitignored) and fill in.
#
#   cp .env.example .env
#
# These power the studio asset pipeline (codex/assetgen images + ElevenLabs SFX).

# ElevenLabs — Sound Effects / TTS API (weapon SFX, voice lines).
# Get a key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# OpenAI — gpt-image-2 image generation (optional fallback; the codex CLI's
# built-in image_gen is the default image path and needs no key).
OPENAI_API_KEY=

# Browser telemetry for shipped games. These are public Vite client values:
# never put secret API keys here.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
VITE_POSTHOG_AUTOCAPTURE=false
VITE_POSTHOG_CAPTURE_PAGEVIEW=false
VITE_POSTHOG_CAPTURE_EXCEPTIONS=false
VITE_POSTHOG_SESSION_REPLAY=false

VITE_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
VITE_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0
VITE_SENTRY_REPLAY_ERROR_SAMPLE_RATE=1

VITE_BALANCE_TELEMETRY_SAMPLE_RATE=1
VITE_BALANCE_TELEMETRY_LOCAL_BUFFER=true
VITE_BALANCE_TELEMETRY_DEBUG=false
VITE_DEADROT_RELEASE=
NEXT_PUBLIC_DEADROT_RELEASE=
VITE_DEADROT_TUNING_VERSION=
