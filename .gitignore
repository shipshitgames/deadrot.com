# Local source archives generated while preparing runtime assets. Curated,
# successful generation history under sources/generated is intentionally tracked.
packages/assets/sources/*
!packages/assets/sources/generated/
!packages/assets/sources/generated/**
packages/assets/sources/generated/*-cache/
packages/assets/sources/generated/gpt-image-*/

# Raw generator caches stay local/review-only; curate keepers into
# packages/assets/sources/generated with semantic names.
packages/assets/_archive/raw-generator-cache/**/raw/**
