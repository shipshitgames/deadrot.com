{
  "name": "deadrot-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "build": "bun build src/server.ts --target=bun --outdir=dist --sourcemap=external",
    "start": "bun dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "bun run test:unit",
    "test:unit": "bun test tests/unit"
  },
  "dependencies": {
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.3",
    "@types/pg": "^8.20.0",
    "typescript": "6.0.3"
  }
}
