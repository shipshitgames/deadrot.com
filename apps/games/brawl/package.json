{
  "name": "brawl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Brawl — a Deadrot one-on-one battlefield fighting game prototype.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "bun run test:unit",
    "test:unit": "bun test tests/unit",
    "test:coverage": "bun test --coverage tests/unit",
    "typecheck": "tsc --noEmit",
    "deps:update": "bunx npm-check-updates -u --cooldown 3h --removeRange && bun install"
  },
  "dependencies": {
    "@deadrot/game-kit": "workspace:*",
    "@shipshitgames/assets": "workspace:*",
    "@shipshitgames/ui": "workspace:*",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
