{
  "name": "scourge-survivors",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k -n game,party -c cyan,magenta \"vite\" \"partykit dev\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "bun run test:unit && bun run test:e2e",
    "test:unit": "vitest run tests/unit",
    "test:coverage": "vitest run tests/unit --coverage",
    "test:e2e": "playwright install chromium && playwright test",
    "typecheck": "tsc --noEmit",
    "party:dev": "partykit dev",
    "party:deploy": "partykit deploy",
    "deps:update": "bunx npm-check-updates -u --cooldown 3h --removeRange && bun install"
  },
  "dependencies": {
    "@deadrot/game-kit": "workspace:*",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@shipshitgames/assets": "workspace:*",
    "@shipshitgames/engine": "^0.2.0",
    "@shipshitgames/ui": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "partysocket": "^1.1.19",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "10.0.3",
    "partykit": "0.0.115",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8"
  }
}
