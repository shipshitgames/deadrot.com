# Early-access paywall (epic #330). All optional: without the Clerk publishable
# key the auth gate and sign-in UI no-op entirely (keyless CI/dev builds stay green).

# ── Clerk (create an application at dashboard.clerk.com) ─────────────────────
# REQUIRED dashboard setup beyond the keys:
#   Sessions → Customize session token → { "metadata": "{{user.public_metadata}}" }
# proxy.ts reads the purchase entitlement from that claim on every gated request.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Stripe (live product prod_UgEAC4hE4TFfoq "deadrot.com") ──────────────────
# Webhook endpoint: POST /api/stripe/webhook, event: checkout.session.completed
# Local dev: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Defaults to the live $4.99 price (price_1Tgri8JLFu10NpzMceH1KZsS) when unset.
STRIPE_PRICE_ID=
