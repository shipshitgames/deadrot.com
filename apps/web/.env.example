# Early-access paywall (epic #330). All optional: without BOTH Clerk keys the
# auth gate and sign-in UI no-op entirely (keyless CI/dev builds stay green).

# ── Clerk (create an application at dashboard.clerk.com) ─────────────────────
# RECOMMENDED dashboard setup beyond the keys (dashboard-only, no API for it):
#   Sessions → Customize session token →
#     { "deadrotCollection": "{{user.public_metadata.deadrotCollection}}" }
# proxy.ts reads the entitlement from that flat claim; without it the gate
# still works but does an authoritative Backend API lookup per gated request.
# The gate only engages when BOTH keys are present.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Keep every Clerk flow on our own pages instead of the hosted Account Portal.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Stripe (live product prod_UgEAC4hE4TFfoq "deadrot.com") ──────────────────
# Webhook endpoint — the trailing slash is LOAD-BEARING (trailingSlash:true
# 308-redirects the slashless URL and Stripe treats redirects as failures):
#   POST https://deadrot.com/api/stripe/webhook/
#   events: checkout.session.completed, checkout.session.async_payment_succeeded
# Local dev: stripe listen --forward-to localhost:3000/api/stripe/webhook/
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Defaults to the live $4.99 price (price_1Tgri8JLFu10NpzMceH1KZsS) when unset.
STRIPE_PRICE_ID=
