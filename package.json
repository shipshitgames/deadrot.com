{
  "name": "deadrotcom",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "apps/games/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:packages": "turbo run lint",
    "test": "bun run test:unit && bun run test:e2e:unit",
    "test:unit": "turbo run test:unit",
    "test:e2e:unit": "bun test e2e/game-catalog.test.ts",
    "test:coverage": "turbo run test:coverage",
    "e2e": "bun run test:e2e",
    "test:e2e": "playwright test",
    "test:e2e:workspaces": "turbo run test:e2e",
    "e2e:docker": "scripts/run-e2e-docker.sh",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "social:check": "node scripts/check-social-metadata.mjs",
    "assets:check": "node scripts/check-assets.mjs",
    "board:hygiene": "node scripts/board-hygiene.mjs",
    "deploy:games:changed": "node scripts/deploy-changed-games.mjs",
    "typecheck": "turbo run typecheck",
    "ci": "bun run format:check && bun run lint && bun run typecheck && bun run social:check && bun run assets:check",
    "deps:update": "bunx npm-check-updates -u --deep --cooldown 3h --removeRange && bun install",
    "doctor": "react-doctor",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "^1.60.0",
    "react-doctor": "^0.4.0",
    "turbo": "2.9.16",
    "typescript": "6.0.3"
  }
}
