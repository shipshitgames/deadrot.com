{
  "name": "deadrotcom",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "apps/games/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "e2e": "playwright test",
    "test:e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "deploy:games:changed": "node scripts/deploy-changed-games.mjs",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "deps:update": "bunx npm-check-updates -u --deep --cooldown 3h --removeRange && bun install"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "turbo": "2.9.16",
    "typescript": "6.0.3"
  }
}
