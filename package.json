{
  "name": "deadrotcom",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "deps:update": "bunx npm-check-updates -u --deep --cooldown 3h --removeRange && bun install"
  },
  "devDependencies": {
    "turbo": "2.9.16",
    "typescript": "6.0.3"
  }
}
