{
  "name": "@shipshitgames/assets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./scourge-survivors": {
      "types": "./src/scourge-survivors.ts",
      "default": "./src/scourge-survivors.ts"
    },
    "./games/*": "./games/*",
    "./shared/*": "./shared/*",
    "./sites/deadrotcom/*": "./sites/deadrotcom/*",
    "./tokens/*": "./tokens/*"
  },
  "files": [
    "assets-catalog.json",
    "assets-catalog.schema.json",
    "entities",
    "games",
    "shared",
    "sites",
    "sources",
    "src",
    "tokens"
  ],
  "scripts": {
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "deps:update": "bunx npm-check-updates -u --cooldown 3h --removeRange && bun install"
  },
  "dependencies": {
    "@deadrot/catalog": "workspace:*"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
