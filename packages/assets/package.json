{
  "name": "@shipshitgames/assets",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./scourge-survivors": {
      "types": "./src/scourge-survivors.ts",
      "default": "./src/scourge-survivors.ts"
    },
    "./lore": {
      "types": "./src/lore.ts",
      "default": "./src/lore.ts"
    },
    "./brand/*": "./brand/*",
    "./concepts/*": "./concepts/*",
    "./entities/*": "./entities/*",
    "./games/*": "./games/*",
    "./shared/*": "./shared/*",
    "./tokens/*": "./tokens/*"
  },
  "files": [
    "assets-catalog.json",
    "assets-catalog.schema.json",
    "brand",
    "concepts",
    "entities",
    "games",
    "lore",
    "shared",
    "src",
    "tokens"
  ],
  "scripts": {
    "assets:check": "node scripts/check-assets.mjs",
    "assets:clean-sprites": "bun ../../../shipshitgames/packages/assetgen/src/cli.ts clean-sprites",
    "assets:sync-codex-images": "node scripts/sync-codex-generated-images.mjs",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests",
    "test:unit": "bun test tests",
    "deps:update": "bunx npm-check-updates -u --cooldown 3h --removeRange && bun install"
  },
  "dependencies": {
    "@deadrot/catalog": "workspace:*"
  },
  "devDependencies": {
    "@deadrot/catalog": "workspace:*",
    "@types/node": "25.9.1",
    "typescript": "6.0.3"
  }
}
