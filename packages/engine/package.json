{
  "name": "@shipshitgames/engine",
  "version": "0.1.1",
  "description": "Ship Shit Games' open-source embodied 3D game engine — the Game/Context/Systems spine, swappable camera rig, embodied movement + collision + world bounds, the agent/steering + spawn + wave-director seams, the generic HUD snapshot shell, input bindings, and replicated presence. One MIT npm package serving every studio title.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "deps:update": "bunx npm-check-updates -u --cooldown 3h --removeRange && bun install"
  },
  "peerDependencies": {
    "three": "^0.169.0"
  },
  "peerDependenciesMeta": {
    "partysocket": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "partysocket": "^1.1.19"
  },
  "devDependencies": {
    "@types/three": "0.184.1",
    "partysocket": "^1.1.19",
    "three": "0.184.0",
    "typescript": "6.0.3"
  },
  "keywords": [
    "game-engine",
    "three",
    "webgl",
    "embodied",
    "shipshit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shipshitgames/deadrotcom.git",
    "directory": "packages/engine"
  }
}
