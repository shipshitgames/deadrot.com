{
  "name": "@deadrot/game-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Deadrot-local shared game runtime: audio engine + procedural SFX palette, juice/VFX (shake, particles, damage numbers, flash), and core loop/RNG/storage/pool/input utilities.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./audio": {
      "types": "./src/audio/index.ts",
      "default": "./src/audio/index.ts"
    },
    "./juice": {
      "types": "./src/juice/index.ts",
      "default": "./src/juice/index.ts"
    },
    "./core": {
      "types": "./src/core/index.ts",
      "default": "./src/core/index.ts"
    },
    "./maps": {
      "types": "./src/maps/index.ts",
      "default": "./src/maps/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests",
    "test:unit": "bun test tests",
    "deps:update": "bunx npm-check-updates -u --cooldown 3h --removeRange && bun install"
  },
  "dependencies": {
    "@shipshitgames/ui": "workspace:*"
  },
  "peerDependencies": {
    "three": ">=0.169.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.184.1",
    "three": "0.184.0",
    "typescript": "6.0.3"
  }
}
