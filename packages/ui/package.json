{
  "name": "@shipshitgames/ui",
  "version": "0.1.0",
  "description": "Shared React UI primitives, menu shells, and DOOM-inspired CSS for Ship Shit Games.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles.css": "./src/styles.css"
  },
  "sideEffects": [
    "./src/styles.css"
  ],
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "deps:update": "bunx npm-check-updates -u --cooldown 3h --removeRange && bun install"
  },
  "dependencies": {
    "@deadrot/catalog": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.3.1 || ^19.0.0",
    "react-dom": "^18.3.1 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "6.0.3"
  },
  "keywords": [
    "react",
    "ui",
    "game-ui",
    "shipshit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shipshitgames/deadrotcom.git",
    "directory": "packages/ui"
  }
}
